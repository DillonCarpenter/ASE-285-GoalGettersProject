<!DOCTYPE html>
<html lang="en" class="index-page">

<head>
  <!-- Required meta tags -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

  <!-- CSS imports -->
  <link rel="stylesheet" href="styles/global.css" />
  <link rel="stylesheet" href="styles/index.css" />
  <link rel="stylesheet" href="styles/write.css" />

  <title>Home</title>
</head>

<body class="index-page">
  <%- include('nav.ejs') %>
  <%- include('write.ejs') %>

  <div class="home-greeting-wrap">
    <h1 id="homeGreeting" class="home-greeting"></h1>
  </div>

  <main class="home-sections page-fade-up">
    <section class="home-card">
      <div class="home-today-header">
        <h2 class="home-today-title">Here's what's on your plate today</h2>
      </div>

      <ul class="today-list no-bullets">
        <% if (typeof todaysTasks !== 'undefined' && todaysTasks.length > 0) { %>
          <% for (let i = 0; i < todaysTasks.length; i++) { %>
            <a href="/detail/<%= todaysTasks[i]._id %>" class="home-today-link">
            <li class="today-list__item">
              <span class="today-list__status <%= todaysTasks[i].completed ? 'is-complete' : '' %>"></span>
              <span class="today-list__title <%= todaysTasks[i].completed ? 'task-title-complete' : '' %>"><%= todaysTasks[i].title %></span>
              <span class="cat-badge cat-<%= (todaysTasks[i].category || 'personal').toLowerCase() %>"><%= todaysTasks[i].category || 'Personal' %></span>
            </li>
            </a>
          <% } %>
        <% } else { %>
          <span>You're all caught up!</span>
        <% } %>
      </ul>
    </section>

    <section class="home-card">
      <div class="home-today-header">
        <h2 class="home-today-title">Coming up soon</h2>
      </div>

      <ul class="today-list no-bullets">
        <% if (typeof comingSoonTasks !== 'undefined' && comingSoonTasks.length > 0) { %>
          <% for (let i = 0; i < comingSoonTasks.length; i++) { %>
            <a href="/detail/<%= comingSoonTasks[i]._id %>" class="home-today-link">
            <li class="today-list__item">
              <span class="today-list__status <%= comingSoonTasks[i].completed ? 'is-complete' : '' %>"></span>
              <span class="today-list__title <%= comingSoonTasks[i].completed ? 'task-title-complete' : '' %>"><%= comingSoonTasks[i].title %></span>
               <span class="cat-badge cat-<%= (comingSoonTasks[i].category || 'personal').toLowerCase() %>"><%= comingSoonTasks[i].category || 'Personal' %></span>
              <span class="today-list__meta"><%= comingSoonTasks[i].date %></span>
            </li>
            </a>
          <% } %>
        <% } else { %>
          <span>No upcoming tasks.</span>
        <% } %>
      </ul>
    </section>
  </main>

  <script>
    (() => {
      const greetingEl = document.getElementById('homeGreeting');
      if (!greetingEl) return;

      const username = "<%= currentUser?.username || '' %>".trim() || "there";
      const hour = new Date().getHours();
      const greeting = hour < 12 ? "Good morning" : "Good afternoon";

      greetingEl.textContent = `👋 ${greeting}, ${username}`;
    })();
  </script>
</body>

</html>